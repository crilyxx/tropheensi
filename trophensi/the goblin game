    obj_x = objectifs_points[0]["x"]
    obj_y = objectifs_points[0]["y"]
    j_x = joueur["x"]
    j_y = joueur["y"]

    for ennemi in ennemis:
        if ennemi["en_spawn"]:
            ennemi["taille_spawn"] += 3
            if ennemi["taille_spawn"] >= ennemi["taille_sprite"]:
                ennemi["taille_spawn"] = ennemi["taille_sprite"]
                ennemi["en_spawn"] = False
            continue

        dx_j = ennemi["x"] - j_x
        dy_j = ennemi["y"] - j_y
        dist_joueur_sq = dx_j * dx_j + dy_j * dy_j

        if dist_joueur_sq < DISTANCE_AGGRO_SQ:
            cible_x, cible_y = j_x, j_y
        else:
            cible_x, cible_y = obj_x, obj_y

        bonus_comp = get_bonus_competences()
        vitesse_joueur_actuelle = joueur["vitesse"] + (bonus_vitesse if mode_infini else bonus_comp["bonus_vitesse"])
        spd = min(ennemi["vitesse"], vitesse_joueur_actuelle - 1)
        if spd < 1:
            spd = 1
        if ennemi["x"] < cible_x:
            ennemi["x"] += spd
        elif ennemi["x"] > cible_x:
            ennemi["x"] -= spd
        if ennemi["y"] < cible_y:
            ennemi["y"] += spd
        elif ennemi["y"] > cible_y:
            ennemi["y"] -= spd

        dx_dir = cible_x - ennemi["x"]
        dy_dir = cible_y - ennemi["y"]
        if abs(dx_dir) > abs(dy_dir):
            ennemi["direction"] = "droite" if dx_dir > 0 else "gauche"
        else:
            ennemi["direction"] = "devant" if dy_dir > 0 else "dos"

        dx_o = ennemi["x"] - obj_x
        dy_o = ennemi["y"] - obj_y
        if dx_o * dx_o + dy_o * dy_o < 1600:
            objectifs_points[0]["hp"] -= ennemi["degats"]

        if dist_joueur_sq < 900:
            bonus = get_bonus_competences()
            joueur["hp"] -= ennemi["degats"] * 0.5 * mult_armure * bonus["mult_defense"]

        col = int(ennemi["x"] / TAILLE_TUILE)
        lig = int(ennemi["y"] / TAILLE_TUILE)
        if 0 <= lig < len(carte_actuelle) and 0 <= col < len(carte_actuelle[0]):
            if carte_actuelle[lig][col] == 1:
                continue

def deplacer_joueur():
