            (16, 52, 3, 4),   # bloc E milieu
            (22, 12, 3, 5),   # bloc SW
            (22, 28, 3, 6),   # bloc S centre
            (22, 48, 3, 5),   # bloc SE
            (26, 5,  3, 4),   # coin bas-gauche
            (26, 53, 3, 4),   # coin bas-droit
        ]
        for (lig_d, col_d, haut, larg) in blocs:
            for dl in range(haut):
                for dc in range(larg):
                    lig = lig_d + dl
                    col = col_d + dc
                    if 0 < lig < nb_lignes - 1 and 0 < col < nb_cols - 1:
                        carte[lig][col] = 1

        # --- Points de spawn répartis dans les zones libres ---
        spawns = [
            (2, 2),   (2, 15),  (2, 30),  (2, 45),  (2, 59),
            (8, 10),  (8, 35),  (8, 55),
            (14, 2),  (14, 25), (14, 50), (14, 59),
            (20, 5),  (20, 22), (20, 40), (20, 58),
            (29, 2),  (29, 20), (29, 40), (29, 59),
        ]
        for col, lig in spawns:
            if 0 < lig < nb_lignes and 0 < col < nb_cols:
                if carte[lig][col] == 0:
                    carte[lig][col] = 3
        return carte
    
    if nom_fichier is None:
        return [[1, 1, 1], [1, 0, 1], [1, 1, 1]]
    chemin_fichier = os.path.join(BASE_DIR, nom_fichier)
    if not os.path.exists(chemin_fichier):
        print(f"ALERTE : Le fichier {chemin_fichier} n'existe pas !")
        return [[1, 1, 1], [1, 0, 1], [1, 1, 1]]
    matrice = []
    with open(chemin_fichier, "r") as f:
        for ligne in f:
            ligne_propre = ligne.strip()
            if ligne_propre:
                matrice.append([int(n) for n in ligne_propre.split(",")])
    
    if nom_fichier == "map_montagne.txt":
        for lig in range(len(matrice)):
            for col in range(len(matrice[lig])):
                if matrice[lig][col] == 4:
                    matrice[lig][col] = 0  # devient sol traversable
    
    return matrice



