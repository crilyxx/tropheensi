def appliquer_effet_statut(cible, type_effet, degats_par_tick, duree_ticks):
    """
    Ajoute un effet de statut (saignement, poison, ralentissement) sur une cible.
    - cible : dictionnaire ennemi ou boss
    - type_effet : "saignement", "poison", "ralentissement"
    - degats_par_tick : degats infliges toutes les 30 frames
    - duree_ticks : nombre de fois que l'effet se declenche (1 tick = 30 frames)
    """
    # Pour le ralentissement : on stocke la vitesse d'origine si ce n'est pas deja fait
    if type_effet == "ralentissement":
        if not cible.get("ralenti", False):
            cible["vitesse_base"] = cible["vitesse"]
            cible["vitesse"] = max(1, cible["vitesse"] // 2)
            cible["ralenti"] = True

    effets_statut.append({
        "cible": cible,
        "type": type_effet,
        "degats": degats_par_tick,
        "duree": duree_ticks,
        "timer": 0
    })


def mettre_a_jour_effets_statut():
    """
    A appeler chaque frame dans mettre_a_jour().
    Applique les degats des effets de statut et supprime les effets expires.
    """
    global effets_statut, score, argent, argent_infini
    nouveaux_effets = []

    for effet in effets_statut:
        cible = effet["cible"]

        # Verifie que la cible est encore en vie et dans le jeu
        if cible not in ennemis and cible is not boss_actif:
            # Si c'etait un ralentissement, pas besoin de restaurer la vitesse
            continue

        if cible.get("hp", 0) <= 0:
            continue

        effet["timer"] += 1

        # Chaque 30 frames (~0.5 seconde), on applique les degats
        if effet["timer"] >= 30:
            effet["timer"] = 0
            if effet["type"] in ("saignement", "poison"):
                cible["hp"] -= effet["degats"]
                cible["timer_hit"] = 5

                # Couleur du texte selon l'effet
                if effet["type"] == "saignement":
                    couleur_txt = (220, 0, 0)
                    suffixe = " saign."
                else:
                    couleur_txt = (80, 220, 80)
                    suffixe = " poison"

                degats_flottants.append({
                    "x": cible["x"] + random.randint(-15, 15),
                    "y": cible["y"] - 30,
                    "texte": f"-{int(effet['degats'])}{suffixe}",
                    "duree": 30,
                    "couleur": couleur_txt
                })

                # Si la cible meurt a cause de l'effet
                if cible["hp"] <= 0 and cible in ennemis:
                    ennemis.remove(cible)
                    score += cible["score"]
                    if mode_infini:
                        argent_infini += cible["argent"]
                    else:
                        argent += cible["argent"]
                    for _ in range(6):
                        particules.append({
                            "x": cible["x"], "y": cible["y"],
                            "vx": random.uniform(-3, 3),
                            "vy": random.uniform(-4, 0),
                            "duree": random.randint(15, 25),
                            "couleur": cible["teinte"]
                        })
                    continue  # Cible morte, on ne garde pas l'effet

            effet["duree"] -= 1
            if effet["duree"] <= 0:
                # L'effet expire : restaure la vitesse si c'etait un ralentissement
                if effet["type"] == "ralentissement" and cible.get("ralenti", False):
                    cible["vitesse"] = cible.get("vitesse_base", cible["vitesse"])
                    cible["ralenti"] = False
                continue

        nouveaux_effets.append(effet)

    effets_statut.clear()
    for e in nouveaux_effets:
        effets_statut.append(e)


def faire_une_attaque(degats, portee, angle_max, dx_vise, dy_vise):
    """
    Effectue une attaque en cone et retourne la liste des ennemis tues.
    Applique aussi les effets speciaux de l'arme courante.
    """
    global combo_poing, timer_combo_poing, message_effet, timer_message_effet
    portee_sq = portee * portee
    morts = []
    ennemis_touches = []  # Liste de tous les ennemis touches (pas seulement les morts)

    effet_arme = armes_stats[arme_actuelle].get("effet", "")

    # --- Gestion du COMBO (poing) ---
    # On incremente le compteur avant de frapper
    if effet_arme == "combo":
        combo_poing += 1
        timer_combo_poing = 90  # 1.5 secondes pour continuer le combo
        if combo_poing >= 3:
            degats = degats * 1.5
            combo_poing = 0
            message_effet = "COMBO x1.5 !"
            timer_message_effet = 60

    for ennemi in ennemis:
        vx = ennemi["x"] - joueur["x"]
        vy = ennemi["y"] - joueur["y"]
        dist_sq = vx * vx + vy * vy

        if dist_sq > portee_sq:
            continue
        if dist_sq == 0:
            continue

        dist = dist_sq ** 0.5
        vx /= dist
        vy /= dist

        dot = max(-1.0, min(1.0, dx_vise * vx + dy_vise * vy))
        angle = math.degrees(math.acos(dot))

        if angle < angle_max:
            degats_reels = degats

            # --- Bonus MARQUAGE : si l'ennemi est deja marque, il subit +50% de degats ---
            # Le marquage est pose par la lance au coup precedent
            if ennemi.get("marque", 0) > 0:
                degats_reels = degats_reels * 1.5

            # --- CRITIQUE (epee) : 25% de chance de doubler les degats ---
            est_critique = False
            if effet_arme == "critique" and random.random() < 0.25:
                degats_reels = degats_reels * 2
                est_critique = True

            # --- ECRASEMENT (katana) : supprime, remplace par FUREUR ---
            # (plus d'ecrasement)

            # --- FUREUR SANGUINE (katana) : bonus de degats selon les stacks ---
            if effet_arme == "fureur" and fureur_stacks > 0:
                degats_reels = degats_reels * (1 + fureur_stacks * 0.15)

            # --- SURCHARGE (foudre) : si le joueur a attendu 2 sec, degats x2 ---
            if effet_arme == "surcharge" and surcharge_prete:
                degats_reels = degats_reels * 2

            ennemi["hp"] -= degats_reels
            ennemi["timer_hit"] = 8
            ennemis_touches.append(ennemi)

            couleur_dmg = (255, 50, 50) if est_critique else (255, 200, 50)
            texte_dmg = f"CRIT! {int(degats_reels)}" if est_critique else str(int(degats_reels))
            degats_flottants.append({
                "x": ennemi["x"] + random.randint(-10, 10),
                "y": ennemi["y"] - 20,
                "texte": texte_dmg,
                "duree": 35,
                "couleur": couleur_dmg
            })

            # --- RECUL (gourdin) : repousse l'ennemi ---
            if effet_arme == "recul":
                force_recul = 60
                ennemi["x"] += dx_vise * force_recul
                ennemi["y"] += dy_vise * force_recul

            # --- RALENTISSEMENT (arbalete) : reduit la vitesse ---
            if effet_arme == "ralentissement":
                appliquer_effet_statut(ennemi, "ralentissement", 0, 6)

            # --- SAIGNEMENT (dague, faux) ---
            if effet_arme == "saignement":
                dgts_saignement = degats * 0.15
                appliquer_effet_statut(ennemi, "saignement", dgts_saignement, 4)

            # --- POISON (trident) ---
            if effet_arme == "poison":
                dgts_poison = degats * 0.10
                appliquer_effet_statut(ennemi, "poison", dgts_poison, 6)

            # --- MARQUAGE (lance) : l'ennemi frappe recoit +50% de degats pendant 3 secondes ---
            # On stocke le timer de marquage directement sur l'ennemi.
            # La penalite est appliquee au prochain coup recu (voir plus bas dans la boucle).
            if effet_arme == "marquage":
                ennemi["marque"] = 180  # 180 frames = 3 secondes a 60 fps
                degats_flottants.append({
                    "x": ennemi["x"] + random.randint(-10, 10),
                    "y": ennemi["y"] - 40,
                    "texte": "MARQUE !",
                    "duree": 40,
                    "couleur": (255, 80, 200)
                })

            if ennemi["hp"] <= 0:
                morts.append(ennemi)

    # --- ONDE DE CHOC (marteau) : repousse TOUS les ennemis proches ---
    if effet_arme == "onde" and ennemis_touches:
        rayon_onde = 150
        for e in ennemis:
            dx_o = e["x"] - joueur["x"]
            dy_o = e["y"] - joueur["y"]
            dist_o = (dx_o**2 + dy_o**2) ** 0.5
            if 0 < dist_o < rayon_onde:
                force = 80 * (1 - dist_o / rayon_onde)
                e["x"] += (dx_o / dist_o) * force
                e["y"] += (dy_o / dist_o) * force
        message_effet = "ONDE DE CHOC !"
        timer_message_effet = 45

    # --- Gestion du BOSS ---
    if boss_actif and not boss_actif["en_spawn"]:
        b = boss_actif
        vx = b["x"] - joueur["x"]
        vy = b["y"] - joueur["y"]
        dist_sq = vx*vx + vy*vy
        if 0 < dist_sq <= portee_sq:
            dist = dist_sq ** 0.5
            vx /= dist; vy /= dist
            dot = max(-1.0, min(1.0, dx_vise*vx + dy_vise*vy))
            if math.degrees(math.acos(dot)) < angle_max:
                degats_boss = degats

                # Critique sur boss
                est_critique_boss = False
                if effet_arme == "critique" and random.random() < 0.25:
                    degats_boss = degats * 2
                    est_critique_boss = True

                # Marquage sur boss : bonus de degats si deja marque
                if b.get("marque", 0) > 0:
                    degats_boss = degats_boss * 1.5

                # Fureur sur boss
                if effet_arme == "fureur" and fureur_stacks > 0:
                    degats_boss = degats_boss * (1 + fureur_stacks * 0.15)

                b["hp"] -= degats_boss
                b["timer_hit"] = 8
                degats_flottants.append({
                    "x": b["x"], "y": b["y"] - 30,
                    "texte": f"CRIT! {int(degats_boss)}" if est_critique_boss else str(int(degats_boss)),
                    "duree": 35,
                    "couleur": (255, 50, 0) if est_critique_boss else (255, 100, 0)
                })

                # Recul sur boss (moins fort)
                if effet_arme == "recul":
                    b["x"] += dx_vise * 20
                    b["y"] += dy_vise * 20

                # Ralentissement sur boss
                if effet_arme == "ralentissement":
                    appliquer_effet_statut(b, "ralentissement", 0, 4)

                # Saignement sur boss
                if effet_arme == "saignement":
                    appliquer_effet_statut(b, "saignement", degats * 0.10, 4)

                # Poison sur boss
                if effet_arme == "poison":
                    appliquer_effet_statut(b, "poison", degats * 0.08, 6)

                # Marquage sur boss
                if effet_arme == "marquage":
                    b["marque"] = 180

    return morts


def appliquer_mort_ennemi(m, morts):
    """
    Gere la mort d'un ennemi : score, argent, particules, et effet TRANCHANT (hache).
    """
    global score, argent, argent_infini, fureur_stacks, timer_fureur

    if m in ennemis:
        ennemis.remove(m)
    score += m["score"]

    # --- FUREUR SANGUINE (katana) : +1 stack par kill, max 5, reset timer ---
    if armes_stats[arme_actuelle].get("effet") == "fureur":
        if fureur_stacks < 5:
            fureur_stacks += 1
        timer_fureur = DUREE_FUREUR

    if mode_infini:
        argent_infini += m["argent"]
    else:
        argent += m["argent"]

    # Boost vampire
    if mode_infini and bonus_vampire > 0:
        nb_stacks = len([b for b in boosts_actifs if b["type"] == "vampire"])
        chance = nb_stacks * 0.25
        if random.random() < chance:
            joueur["hp"] = min(joueur["hp_max"], joueur["hp"] + bonus_vampire)

    for _ in range(8):
        particules.append({
            "x": m["x"], "y": m["y"],
            "vx": random.uniform(-3, 3),
            "vy": random.uniform(-4, 0),
            "duree": random.randint(15, 25),
            "couleur": m["teinte"]
        })

    degats_flottants.append({
        "x": m["x"], "y": m["y"] - 20,
        "texte": str(m["hp_max"]),
        "duree": 40,
        "couleur": (255, 80, 80)
    })

    # --- TRANCHANT (hache) : l'ennemi explose et blesse ceux autour ---
    if armes_stats[arme_actuelle].get("effet") == "tranchant":
        rayon_explosion = 100
        degats_explosion = armes_stats[arme_actuelle]["degats"] * 0.4
        for autre in ennemis[:]:
            if autre is m:
                continue
            dx_e = autre["x"] - m["x"]
            dy_e = autre["y"] - m["y"]
            if dx_e*dx_e + dy_e*dy_e < rayon_explosion**2:
                autre["hp"] -= degats_explosion
                autre["timer_hit"] = 6
                degats_flottants.append({
                    "x": autre["x"], "y": autre["y"] - 20,
                    "texte": f"Explos. {int(degats_explosion)}", "duree": 30, "couleur": (255, 140, 0)
                })
                if autre["hp"] <= 0 and autre not in morts:
                    morts.append(autre)
        # Particules d'explosion
        for _ in range(12):
            particules.append({
                "x": m["x"], "y": m["y"],
                "vx": random.uniform(-6, 6),
                "vy": random.uniform(-6, 1),
                "duree": random.randint(10, 22),
                "couleur": (255, 120, 0)
            })

    # --- PERFORATION (lance) : soigne legèrement si on perce plusieurs ennemis ---
    # (pas de soin ici, c'est gere dans faire_une_attaque directement)


def attaquer():
    global score, argent, argent_infini, timer_visuel_attaque, timer_attaque
    global combo_poing, timer_combo_poing, message_effet, timer_message_effet
    global timer_surcharge, surcharge_prete, score_total, points_competences 

    stats = armes_stats[arme_actuelle]

    if timer_attaque > 0:
        return

    joueur["etat_anim"] = "attaque"
    joueur["frame_actuelle"] = 0
    joueur["timer_anim"] = 0

    if mode_infini:
        portee   = get_portee_arme(arme_actuelle) * mult_portee
        degats   = get_degats_arme(arme_actuelle) * mult_degats * boost_degats_bulle
        cooldown = int(get_cooldown_arme(arme_actuelle) * mult_cooldown)
        if cooldown < 2:
            cooldown = 2
        angle_max = min(179, stats["angle"] * mult_angle)
    else:
        bonus_comp = get_bonus_competences()
        portee    = get_portee_arme(arme_actuelle)
        degats    = get_degats_arme(arme_actuelle) * bonus_comp["mult_degats"] * boost_degats_bulle
        cooldown  = get_cooldown_arme(arme_actuelle)
        angle_max = stats["angle"]

    # --- SURCHARGE (foudre) : verifie si le timer est a 120 avant de frapper ---
    surcharge_prete = (arme_actuelle == "foudre" and timer_surcharge >= 120)
    if surcharge_prete:
        message_effet = "SURCHARGE ! x2 DEGATS !"
        timer_message_effet = 60
    # On remet le timer a 0 apres avoir attaque
    timer_surcharge = 0

    # --- Reduction de cooldown katana a partir de 3 stacks de fureur ---
    if arme_actuelle == "katana" and fureur_stacks >= 3:
        reduction = (fureur_stacks - 2) * 0.05
        cooldown  = max(2, int(cooldown * (1.0 - reduction)))

    timer_attaque = cooldown
    timer_visuel_attaque = 0

    cam_x, cam_y = calcul_camera(joueur, carte_actuelle)
    mx, my = souris_vers_jeu(pygame.mouse.get_pos())
    mx += cam_x
    my += cam_y

    dx = mx - joueur["x"]
    dy = my - joueur["y"]
    distance = (dx**2 + dy**2) ** 0.5

    if distance == 0:
        return

    dx /= distance
    dy /= distance

    morts = faire_une_attaque(degats, portee, angle_max, dx, dy)

    # Double frappe mode infini
    if mode_infini and double_frappe:
        if random.random() < 0.30:
            morts2 = faire_une_attaque(degats, portee, angle_max, dx, dy)
            for m in morts2:
                if m not in morts:
                    morts.append(m)

    ennemis_deja_traites = set()
    for m in morts:
        if id(m) not in ennemis_deja_traites:
            ennemis_deja_traites.add(id(m))
            appliquer_mort_ennemi(m, morts)

def souris_vers_jeu(pos):
    fenetre_largeur, fenetre_hauteur = ecran.get_size()
    ratio_x = fenetre_largeur / l
    ratio_y = fenetre_hauteur / h
    ratio = min(ratio_x, ratio_y)
    nouvelle_largeur = int(l * ratio)
    nouvelle_hauteur = int(h * ratio)
    offset_x = (fenetre_largeur - nouvelle_largeur) // 2
    offset_y = (fenetre_hauteur - nouvelle_hauteur) // 2
    x = (pos[0] - offset_x) / ratio
    y = (pos[1] - offset_y) / ratio
    return int(x), int(y)

def s(val):
    return int(val * SCALE)

