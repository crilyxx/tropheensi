def dessiner_carte(cam_x, cam_y):
    if not carte_actuelle or not carte_actuelle[0]:
        return
    col_min = max(0, cam_x // TAILLE_TUILE)
    col_max = min(len(carte_actuelle[0]), (cam_x + screen_width) // TAILLE_TUILE + 1)
    lig_min = max(0, cam_y // TAILLE_TUILE)
    lig_max = min(len(carte_actuelle), (cam_y + screen_height) // TAILLE_TUILE + 1)

    for lig in range(lig_min, lig_max):
        for col in range(col_min, col_max):
            tuile = carte_actuelle[lig][col]
            image_a_dessiner = images_tuiles.get(tuile) 
            
            if image_a_dessiner is not None:
                surface_jeu.blit(
                    image_a_dessiner,
                    (col * TAILLE_TUILE - cam_x, lig * TAILLE_TUILE - cam_y)
                )

def dessiner_jeu():
    global timer_visuel_attaque, boss_anim_spawn
    cam_x, cam_y = calcul_camera(joueur, carte_actuelle)
    couleur_fond_themes = {
        "foret":    (10, 20, 10),
        "desert":   (120, 90, 30),
        "ile":      (0, 60, 100),
        "montagne": (80, 80, 100),
        "espace":   (5, 5, 20),
    }
    surface_jeu.fill(couleur_fond_themes.get(theme_actuel, noir))
    
    if theme_actuel == "espace":
        surface_jeu.blit(fond_espace, (-cam_x, -cam_y))
    else:
        dessiner_carte(cam_x, cam_y)

    mx, my = souris_vers_jeu(pygame.mouse.get_pos())
    mx += cam_x
    my += cam_y

    stats = armes_stats[arme_actuelle]

    if mode_infini:
        portee    = stats["portee"]  * mult_portee
        angle_deg = min(179, stats["angle"] * mult_angle)
    else:
        portee    = stats["portee"]
        angle_deg = stats["angle"]

    dx = mx - joueur["x"]
    dy = my - joueur["y"]
    distance = (dx**2 + dy**2) ** 0.5

    if distance != 0:
        dx /= distance
        dy /= distance

    angle_base = math.atan2(dy, dx)
    angle_rad = math.radians(angle_deg)

    cache_key = (joueur["x"], joueur["y"], round(mx, 1), round(my, 1), arme_actuelle, round(mult_angle, 2))
    if _cone_cache["key"] != cache_key:
        points = [(joueur["x"], joueur["y"])]
        nb_points = 20
        for i in range(nb_points + 1):
            angle = angle_base - angle_rad / 2 + (angle_rad * i / nb_points)
            x = joueur["x"] + math.cos(angle) * portee
            y = joueur["y"] + math.sin(angle) * portee
            points.append((x, y))
        _cone_cache["key"] = cache_key
        _cone_cache["points"] = points
    else:
        points = _cone_cache["points"]

    surface_alpha.fill((0, 0, 0, 0))

    # Couleur du cone selon l'arme (12 armes)
    couleurs_armes = {
        "poing":    (255, 200, 100, 80),
        "gourdin":  (180, 140, 80,  80),
        "dague":    (255, 255, 80,  80),
        "epee":     (150, 220, 255, 80),
        "faux":     (100, 255, 200, 80),
        "lance":    (100, 255, 150, 80),
        "hache":    (255, 100, 50,  80),
        "trident":  (80,  200, 255, 80),
        "arbalete": (200, 100, 255, 80),
        "marteau":  (220, 50,  255, 80),
        "foudre":   (255, 255, 0,   120),
        "katana":   (255, 50,  100, 80),
    }
    couleur = couleurs_armes.get(arme_actuelle, (200, 200, 200, 80))
    # Le cone du katana devient plus rouge avec les stacks de fureur
    if arme_actuelle == "katana" and fureur_stacks > 0:
        intensite = min(255, 50 + fureur_stacks * 40)
        couleur   = (255, intensite, 0, 80 + fureur_stacks * 15)

    points_cam = [(x - cam_x, y - cam_y) for x, y in points]
    pygame.draw.polygon(surface_alpha, couleur, points_cam)
    surface_jeu.blit(surface_alpha, (0, 0))

    if joueur["etat_anim"] == "attaque":
        cle = f"attaque_{joueur['direction']}"
    elif joueur["en_mouvement"]:
        cle = joueur["direction"]
    else:
        cle = f"idle_{joueur['direction']}"

    img_joueur = frames_joueur[cle][joueur["frame_actuelle"]]
    surface_jeu.blit(img_joueur, (
        int(joueur["x"] - cam_x - img_joueur.get_width() // 2),
        int(joueur["y"] - cam_y - img_joueur.get_height() // 2)
    ))

    if mode_infini:
        cd_max = int(stats["cooldown"] * mult_cooldown)
    else:
        cd_max = stats["cooldown"]
    if cd_max < 1:
        cd_max = 1
    ratio = 1 - (timer_attaque / cd_max) if cd_max > 0 else 1
    largeur_max = 50
