def jouer_musique(theme):
    global theme_musique_actuel
    if theme == theme_musique_actuel:
        return
    chemin = musiques_themes.get(theme, "")
    if os.path.exists(chemin):
        pygame.mixer.music.stop()
        pygame.mixer.music.load(chemin)
        pygame.mixer.music.set_volume(0.4)
        pygame.mixer.music.play(-1)
        theme_musique_actuel = theme

