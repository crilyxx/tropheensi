def max_debloque_competence(cle):
    """Retourne le nombre de niveaux débloqués selon la progression en histoire."""
    if cle == "vitesse":
        return competences["vitesse"]["max"]  # vitesse toujours limitée à 5
    # 10 niveaux de compétence débloqués par thème complété
    # thème 1 : niv 1-10  → 10 pts, thème 2 : 11-20 → 20 pts, etc.
    paliers = [10, 20, 30, 40, 50]   # niveaux histoire franchis
    debloques = [10, 20, 30, 40, 50] # niveaux de compétence correspondants
    for i in range(len(paliers) - 1, -1, -1):
        if niveau_max > paliers[i]:
            return debloques[i]
    if niveau_max >= 1:
        return min(10, niveau_max)   # on débloque 1 par niveau dans le 1er thème
    return 0
