def _spawner_mob_autour_boss(b):
    """Crée un ennemi aléatoire dans un rayon autour du boss."""
    angle_r = random.uniform(0, 2 * math.pi)
    rayon = random.randint(80, 200)
    x = b["x"] + math.cos(angle_r) * rayon
    y = b["y"] + math.sin(angle_r) * rayon
    # Crée un gobelin simple (le plus petit) au point calculé
    liste_disponible = types_gobelins[type_gobelin_actuel]
    config = liste_disponible[random.randint(0, 1)]  # petit ou moyen seulement
    mult = 1.0 + (numero_vague_infinie - 1) * 0.08 if mode_infini else 1.0 + (numero_niveau - 1) * 0.1
    taille_sprite = config["taille"]
    teinte = (255, 180, 100)
    frames_precalculees = {}

    source_frames_boss = frames_ennemi_par_theme.get(theme_actuel, frames_ennemi_feu)
    for direction, liste_frames in source_frames_boss.items():
        frames_precalculees[direction] = []
        for frame in liste_frames:
            f = pygame.transform.smoothscale(frame, (taille_sprite, taille_sprite))
            f = ennemi_colore(f, teinte)
            frames_precalculees[direction].append(f)
    ennemis.append({
        "x": x, "y": y,
        "img": frames_precalculees["devant"][0],
        "taille_sprite": taille_sprite, "teinte": teinte,
        "frames": frames_precalculees,
        "hp": int(config["hp"] * mult), "hp_max": int(config["hp"] * mult),
        "type": config["type"], "score": config["score"] // 2,
        "argent": 1, "vitesse": config["vitesse"],
        "degats": config["degats"] * mult,
        "timer_anim": random.randint(0, 20), "frame_actuelle": 0,
        "direction": "devant", "timer_hit": 0,
        "taille_spawn": 0, "en_spawn": True,
    })

def _mort_boss():
    global boss_actif, score, argent, argent_infini
    b = boss_actif
    score += b["score"]
    if mode_infini:
        argent_infini += b["argent"] * 2
    else:
        argent += b["argent"]
    for _ in range(25):
        particules.append({
            "x": b["x"] + random.randint(-50, 50),
            "y": b["y"] + random.randint(-50, 50),
            "vx": random.uniform(-6, 6), "vy": random.uniform(-7, 0),
            "duree": random.randint(25, 50), "couleur": b["teinte"]
        })
    boss_actif = None

def logique_boss():
    global boss_actif, score, argent, argent_infini, boss_timer_capacite

    if boss_actif is None:
        return

    if boss_actif["en_spawn"]:
        boss_actif["taille_spawn"] += 4
        if boss_actif["taille_spawn"] >= boss_actif["taille_sprite"]:
            boss_actif["taille_spawn"] = boss_actif["taille_sprite"]
            boss_actif["en_spawn"] = False
        return

    j_x, j_y = joueur["x"], joueur["y"]
    b = boss_actif
    boss_timer_capacite += 1

    dx_j = b["x"] - j_x
    dy_j = b["y"] - j_y
    dist_sq = dx_j * dx_j + dy_j * dy_j
    dist = dist_sq ** 0.5

    # --- STUN : le boss est immobilisé ---
    if b["stun_timer"] > 0:
        b["stun_timer"] -= 1
        b["etat_anim"] = "hit"
        # Animation même stunné
        b["timer_anim"] += 1
        if b["timer_anim"] >= 8:
            b["timer_anim"] = 0
            frames_list = b["frames"].get("hit", b["frames"].get("walk", list(b["frames"].values())[0]))
            b["frame_actuelle"] = (b["frame_actuelle"] + 1) % len(frames_list)
        if b["hp"] <= 0:
            _mort_boss()
        return

    # --- Direction vers le joueur ---
    if abs(dx_j) > abs(dy_j):
        b["direction"] = "droite" if j_x > b["x"] else "gauche"
    else:
        b["direction"] = "devant" if j_y > b["y"] else "dos"

    distance_arret = b.get("distance_arret", 100)

    # ============================================================
    # TROLL : Invocateur — garde ses distances, invoque des mobs
    # ============================================================
    if b["capacite"] == "invocateur":
        # Phase : si joueur trop proche → recul
        if dist < distance_arret:
            b["phase"] = "recul"
        elif dist > distance_arret + 100:
            b["phase"] = "approche"
        else:
            b["phase"] = "invasion"  # bonne distance → invoque

        if b["phase"] == "recul":
            # S'éloigne du joueur
            if dist > 0:
                b["x"] -= (j_x - b["x"]) / dist * b["vitesse"]
                b["y"] -= (j_y - b["y"]) / dist * b["vitesse"]
            b["etat_anim"] = "walk"
        elif b["phase"] == "approche":
            # Se rapproche jusqu'à distance_arret
            if dist > 0:
                b["x"] += (j_x - b["x"]) / dist * b["vitesse"]
                b["y"] += (j_y - b["y"]) / dist * b["vitesse"]
            b["etat_anim"] = "walk"
        else:
            # Invasion : reste sur place et invoque
            b["etat_anim"] = "idle" if "idle" in b["frames"] else "walk"

        # Invoque des mobs toutes les 4 secondes
        b["timer_spawn_mob"] += 1
        if b["timer_spawn_mob"] >= 240:
            b["timer_spawn_mob"] = 0
            nb_a_spawner = random.randint(2, 4)
            for _ in range(nb_a_spawner):
                if len(ennemis) < MAX_ENNEMIS:
                    _spawner_mob_autour_boss(b)

        # Petits dégâts de contact seulement si très proche
        if dist < 80:
            joueur["hp"] -= b["degats_joueur"] * mult_armure

    # ============================================================
    # CHAMANE : Assassin — fonce sur le joueur, se fais stunt facilement
    # ============================================================
    elif b["capacite"] == "assassin":
        b["timer_phase"] += 1

        # Comportement : charge périodique puis pause
        if b["phase"] == "chasse":
            # Fonce vers le joueur
            if dist > distance_arret and dist > 0:
                vitesse_charge = b["vitesse"] + 2  # plus rapide que la normale
                b["x"] += (j_x - b["x"]) / dist * vitesse_charge
                b["y"] += (j_y - b["y"]) / dist * vitesse_charge
            b["etat_anim"] = "walk"

            # Dégâts au contact
            if dist < 55:
                joueur["hp"] -= b["degats_joueur"] * mult_armure

            # Change de phase toutes les 3 secondes : courte pause
            if b["timer_phase"] >= 180:
                b["timer_phase"] = 0
                b["phase"] = "pause"

        elif b["phase"] == "pause":
            # Petite pause avant de rechargez
            b["etat_anim"] = "idle" if "idle" in b["frames"] else "walk"
            if b["timer_phase"] >= 45:
                b["timer_phase"] = 0
                b["phase"] = "chasse"

        # Stun : le chamane se stun si touché (géré dans faire_une_attaque,
        # ici on juste décrémente le timer_hit → si timer_hit > 5 → stun déclenché)
        if b["timer_hit"] >= 7:
            b["stun_timer"] = 40  # 0.66 secondes de stun

    # ============================================================
    # ROI : Commandant — invoque, se régénère, frappe à mi-distance
    # ============================================================
    elif b["capacite"] == "commandant":
        b["timer_phase"] += 1

        if b["phase"] == "chasse":
            # Se rapproche jusqu'à distance_arret
            if dist > distance_arret and dist > 0:
                b["x"] += (j_x - b["x"]) / dist * b["vitesse"]
                b["y"] += (j_y - b["y"]) / dist * b["vitesse"]
            b["etat_anim"] = "walk"

            # Dégâts à distance_arret (frappe avec portée)
            if dist < distance_arret + 20:
                joueur["hp"] -= b["degats_joueur"] * mult_armure

            # Alterne entre chasse et commandement
            if b["timer_phase"] >= 300:
                b["timer_phase"] = 0
                b["phase"] = "commandement"

        elif b["phase"] == "commandement":
            # S'arrête, invoque des mobs et se régénère
            b["etat_anim"] = "idle" if "idle" in b["frames"] else "walk"
            b["regen_timer"] += 1
            if b["regen_timer"] >= 20:  # regen rapide pendant la phase commandement
                b["regen_timer"] = 0
                b["hp"] = min(b["hp_max"], b["hp"] + 3)

            b["timer_spawn_mob"] += 1
            if b["timer_spawn_mob"] >= 90:
                b["timer_spawn_mob"] = 0
                if len(ennemis) < MAX_ENNEMIS:
                    _spawner_mob_autour_boss(b)

            if b["timer_phase"] >= 180:
                b["timer_phase"] = 0
                b["phase"] = "chasse"

    # --- Animation commune ---
    b["timer_anim"] += 1
    if b["timer_anim"] >= 8:
        b["timer_anim"] = 0
        frames_list = b["frames"].get(b.get("etat_anim", "walk"), b["frames"].get("walk", list(b["frames"].values())[0]))
        b["frame_actuelle"] = (b["frame_actuelle"] + 1) % max(1, len(frames_list))

    if b["hp"] <= 0:
        _mort_boss()

