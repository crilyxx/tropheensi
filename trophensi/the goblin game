def choisir_boosts():
    """Tire au sort 3 boosts a proposer au joueur apres chaque vague."""
    global boosts_proposes
    boosts_normaux = [b for b in LISTE_BOOSTS if not b.get("rare", False)]
    boosts_rares   = [b for b in LISTE_BOOSTS if b.get("rare", False)]

    pool = boosts_normaux[:]
    # Un boost rare apparait tous les 3 vagues
    if numero_vague_infinie % 3 == 0:
        pool = pool + boosts_rares

    boosts_proposes = random.sample(pool, min(3, len(pool)))


def appliquer_boost(boost):
    """Applique l'effet du boost choisi par le joueur."""
    global mult_degats, mult_portee, mult_angle, bonus_vitesse
    global mult_cooldown, mult_armure, bonus_vampire, bonus_magnet, double_frappe

    if boost["type"] == "degats":
        mult_degats = mult_degats * (1 + boost["valeur"])

    elif boost["type"] == "portee":
        mult_portee = mult_portee * (1 + boost["valeur"])

    elif boost["type"] == "angle":
        mult_angle = mult_angle * (1 + boost["valeur"])

    elif boost["type"] == "vitesse":
        bonus_vitesse = bonus_vitesse + boost["valeur"]

    elif boost["type"] == "hp_max":
        joueur["hp_max"] = joueur["hp_max"] + boost["valeur"]
        joueur["hp"] = joueur["hp_max"]

    elif boost["type"] == "cooldown":
        mult_cooldown = mult_cooldown * (1 - boost["valeur"])

    elif boost["type"] == "soin":
        joueur["hp"] = joueur["hp"] + boost["valeur"]
        if joueur["hp"] > joueur["hp_max"]:
            joueur["hp"] = joueur["hp_max"]

    elif boost["type"] == "armure":
        mult_armure = mult_armure * (1 - boost["valeur"])

    elif boost["type"] == "vampire":
        bonus_vampire = bonus_vampire + boost["valeur"]

    elif boost["type"] == "magnet":
        bonus_magnet = bonus_magnet + boost["valeur"]

    elif boost["type"] == "double":
        double_frappe = True

    elif boost["type"] == "berserk":
        mult_degats = mult_degats * (1 + boost["valeur"])
        joueur["hp_max"] = joueur["hp_max"] - 8
        if joueur["hp_max"] < 10:
            joueur["hp_max"] = 10
        if joueur["hp"] > joueur["hp_max"]:
            joueur["hp"] = joueur["hp_max"]

    elif boost["type"] == "fortifie":
        # Boost rare : +30 HP max ET +20% armure
        joueur["hp_max"] = joueur["hp_max"] + boost["valeur"]
        joueur["hp"] = joueur["hp_max"]
        mult_armure = mult_armure * 0.80

    boosts_actifs.append(boost)


