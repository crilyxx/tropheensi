                # Calculer la ligne actuelle
                total = 0
                for i, ligne in enumerate(lore_actif["lignes"]):
                    total += len(ligne)
                    if lore_index_lettre <= total:
                        lore_ligne_actuelle = i
                        break
                # Tout affiché ?
                total_chars = sum(len(l) for l in lore_actif["lignes"])
                if lore_index_lettre >= total_chars:
                    lore_index_lettre = total_chars
                    lore_texte_complet = True
        return
    
    # Timer du combo poing : si le joueur n'attaque pas, le combo se remet a 0
    if timer_combo_poing > 0:
        timer_combo_poing -= 1
    elif combo_poing > 0:
        combo_poing = 0

    # Timer du message d'effet a l'ecran
    if timer_message_effet > 0:
        timer_message_effet -= 1

    # Decrementer le timer de marquage sur chaque ennemi
    for e in ennemis:
        if e.get("marque", 0) > 0:
            e["marque"] -= 1
    if boss_actif and boss_actif.get("marque", 0) > 0:
        boss_actif["marque"] -= 1

    # Surcharge (foudre) : le timer monte quand on n'attaque pas.
    # A 120 frames (2 secondes), la surcharge est prete.
    # Elle se remet a 0 des qu'on attaque (gere dans attaquer()).
    if arme_actuelle == "foudre":
        if timer_surcharge < 120:
            timer_surcharge += 1
        # surcharge_prete est mis a jour dans attaquer() apres consommation
    else:
        # Si on change d'arme, on remet le timer a 0
        timer_surcharge = 0

    if ennemis_spawnes_vague < ennemis_par_vague:
        timer_ennemi += 1
        if timer_ennemi >= delai_ennemi:
            nb_spawn = 1 + (numero_niveau - 1) // 3
            for _ in range(nb_spawn):
                if ennemis_spawnes_vague < ennemis_par_vague:
                    creer_ennemi()
                    ennemis_spawnes_vague += 1
            timer_ennemi = 0
    
    # --- FUREUR SANGUINE : decrement du timer, perte des stacks a 0 ---
    if fureur_stacks > 0:
        timer_fureur -= 1
        if timer_fureur <= 0:
            fureur_stacks = 0
            timer_fureur  = 0

    seuil_fin = max(1, ennemis_par_vague // 10)
    tous_spawnes = ennemis_spawnes_vague >= ennemis_par_vague
    presque_tous_morts = len(ennemis) <= seuil_fin
    boss_mort = boss_actif is None

    if tous_spawnes and presque_tous_morts and boss_mort:

        if mode_infini:
            choisir_boosts()
            etat = "choix_boost"
            return

        if vague_actuelle < nb_vagues_total:
            vague_actuelle += 1
            ennemis_spawnes_vague = 0
            ennemis_tues_vague = 0
            ennemis.clear()
            timer_ennemi = 0
            # Petit soin de fin de vague (mode histoire)
            soin_vague = 5
            joueur["hp"] = min(joueur["hp_max"], joueur["hp"] + soin_vague)
            objectifs_points[0]["hp"] = min(objectifs_points[0]["hp_max"], objectifs_points[0]["hp"] + 10)
            degats_flottants.append({
                "x": joueur["x"], "y": joueur["y"] - 30,
                "texte": f"+{soin_vague} HP (vague)", "duree": 60,
                "couleur": (80, 255, 120)
            })
            if vague_actuelle == nb_vagues_total and boss_type_niveau and not boss_spawne:
                creer_boss(boss_type_niveau)
                boss_spawne = True
        else:
            if numero_niveau == niveau_max and niveau_max < len(niveaux):
                niveau_max += 1
            score_total += score
            points_competences += score // 500
            sauvegarder(slot_actuel)
            if numero_niveau in LORE_NIVEAUX:
                lore_actif = LORE_NIVEAUX[numero_niveau]
                lore_index_lettre = 0
                lore_timer = 0
                lore_ligne_actuelle = 0
                lore_texte_complet = False
                etat = "lore"
            else:
                etat = "niveau_gagne"
            return

    if joueur["hp"] <= 0:
        etat = "game_over"
        return
    if objectifs_points[0]["hp"] <= 0:
        etat = "game_over"
        return

    if timer_attaque > 0:
        timer_attaque -= 1
    if timer_visuel_attaque > 0:
        timer_visuel_attaque -= 1

    nb_p = len(particules)
    for _ in range(nb_p):
        p = particules.popleft()
        p["x"] += p["vx"]; p["y"] += p["vy"]; p["vy"] += 0.2; p["duree"] -= 1
        if p["duree"] > 0: particules.append(p)

    nb_d = len(degats_flottants)
    for _ in range(nb_d):
        d = degats_flottants.popleft()
        d["y"] -= 1; d["duree"] -= 1
        if d["duree"] > 0: degats_flottants.append(d)

    deplacer_joueur()

    if mode_infini and boss_type_niveau and not boss_spawne:
        if ennemis_spawnes_vague >= ennemis_par_vague:
            creer_boss(boss_type_niveau)
            boss_spawne = True

