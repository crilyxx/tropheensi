def creer_bulle():
    """Fait apparaître une bulle de bonus aléatoire près du centre de la carte."""
    if not carte_actuelle or not carte_actuelle[0]:
        return
    largeur_carte = len(carte_actuelle[0]) * TAILLE_TUILE
    hauteur_carte = len(carte_actuelle) * TAILLE_TUILE
    cx = largeur_carte // 2
    cy = hauteur_carte // 2

    # Zone de spawn : carré de 400px autour du centre
    rayon = 700
    for _ in range(20):  # 20 tentatives pour trouver une case libre
        x = cx + random.randint(-rayon, rayon)
        y = cy + random.randint(-rayon, rayon)
        col = int(x / TAILLE_TUILE)
        lig = int(y / TAILLE_TUILE)
        if 0 <= lig < len(carte_actuelle) and 0 <= col < len(carte_actuelle[0]):
            if carte_actuelle[lig][col] not in SOLIDES:
                config = random.choice(TYPES_BULLES)
                if config["type"] == "soin":
                    label_affiche = f"+{max(1, int(joueur['hp_max'] * 0.07))} HP"
                else:
                    label_affiche = config["label"]
                bulles.append({
                    "x": x, "y": y,
                    "type": config["type"],
                    "couleur": config["couleur"],
                    "valeur": config["valeur"],
                    "label": label_affiche,
                    "rayon": 18,
                    "timer_pulse": random.randint(0, 60),  # déphasage visuel
                    "duree_vie": 600,  # disparaît après 10 secondes si non ramassée
                })
                return
            
def mettre_a_jour_bulles():
    global bulles, timer_spawn_bulle, boost_degats_bulle, timer_boost_degats_bulle

    # Spawn périodique (seulement pendant une vague active)
    if ennemis_spawnes_vague > 0 or len(ennemis) > 0:
        timer_spawn_bulle += 1
        if timer_spawn_bulle >= DELAI_SPAWN_BULLE:
            timer_spawn_bulle = 0
            if len(bulles) < 4:  # max 4 bulles à la fois
                creer_bulle()

    # Timer du boost de dégâts (bulle dorée)
    if timer_boost_degats_bulle > 0:
        timer_boost_degats_bulle -= 1
        if timer_boost_degats_bulle == 0:
            boost_degats_bulle = 1.0  # le boost expire

    nouvelles_bulles = []
    for b in bulles:
        b["timer_pulse"] += 1
        b["duree_vie"] -= 1

        if b["duree_vie"] <= 0:
            continue  # la bulle disparaît

        # Collision avec le joueur (rayon 30px)
        dx = joueur["x"] - b["x"]
        dy = joueur["y"] - b["y"]
        if dx*dx + dy*dy < (b["rayon"] + 30) ** 2:
            # Ramassée !
            if b["type"] == "soin":
                soin = max(1, int(joueur["hp_max"] * 0.07))
                joueur["hp"] = min(joueur["hp_max"], joueur["hp"] + soin)
                objectifs_points[0]["hp"] = min(
                    objectifs_points[0]["hp_max"],
                    objectifs_points[0]["hp"] + soin // 2
                )
                b["label"] = f"+{soin} HP"
                degats_flottants.append({
                    "x": b["x"], "y": b["y"] - 20,
                    "texte": f"+{soin} HP (10%)", "duree": 50,
                    "couleur": (80, 255, 120)
                })
            elif b["type"] == "degats":
                boost_degats_bulle = 1.0 + b["valeur"]
                timer_boost_degats_bulle = DUREE_BOOST_DEGATS_BULLE
                degats_flottants.append({
                    "x": b["x"], "y": b["y"] - 20,
                    "texte": b["label"], "duree": 50,
                    "couleur": (255, 200, 50)
                })
            # Particules de ramassage
            for _ in range(10):
                particules.append({
                    "x": b["x"], "y": b["y"],
                    "vx": random.uniform(-4, 4),
                    "vy": random.uniform(-5, 0),
                    "duree": random.randint(15, 30),
                    "couleur": b["couleur"]
                })
            continue  # ne pas garder la bulle

        nouvelles_bulles.append(b)

    bulles.clear()
    for b in nouvelles_bulles:
        bulles.append(b)
