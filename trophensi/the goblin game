def sauvegarder(slot):
    global niveau_max, argent, armes_debloquees, score_total, points_competences, competences
    if slot == 0:
        return
    try:
        with open(f"save{slot}.txt", "w") as f:
            f.write(f"{niveau_max}\n")
            f.write(f"{argent}\n")
            for arme in ARMES_SHOP:
                f.write(f"{int(armes_debloquees[arme])}\n")
            for arme in armes_stats:
                f.write(f"{armes_niveaux.get(arme, 0)}\n")
            f.write(f"{score_total}\n")
            f.write(f"{points_competences}\n")
            for cle in competences:
                f.write(f"{competences[cle]['niveau']}\n")
    except Exception as e:
        print(f"Erreur sauvegarde : {e}")

def charger(slot):
    global niveau_max, argent, armes_debloquees, slot_actuel
    global score_total, points_competences, competences, armes_niveaux
    slot_actuel = slot
    try:
        with open(f"save{slot}.txt", "r") as f:
            lignes = f.readlines()
            idx = 0
            niveau_max         = int(lignes[idx].strip()); idx += 1
            argent             = int(lignes[idx].strip()); idx += 1
            for arme in ARMES_SHOP:
                armes_debloquees[arme] = int(lignes[idx].strip()); idx += 1
            for arme in armes_stats:
                armes_niveaux[arme] = int(lignes[idx].strip()); idx += 1
            score_total        = int(lignes[idx].strip()); idx += 1
            points_competences = int(lignes[idx].strip()); idx += 1
            for cle in competences:
                competences[cle]["niveau"] = int(lignes[idx].strip()); idx += 1
    except Exception as e:
        print(f"Erreur chargement slot {slot} : {e}")
        niveau_max = 1
        argent = 0
        armes_debloquees = {a: 0 for a in ARMES_SHOP}
        armes_niveaux    = {a: 0 for a in armes_stats}
        score_total = 0
        points_competences = 0
        for cle in competences:
            competences[cle]["niveau"] = 0
    niveau_max = max(1, niveau_max)

def recuperer_infos_save(slot):
    try:
        with open(f"save{slot}.txt", "r") as f:
            lignes = f.readlines()
            if len(lignes) >= 2 + len(ARMES_SHOP):
                niv = lignes[0].strip()
                arg = lignes[1].strip()
                nb = sum(int(lignes[2 + i].strip()) for i in range(len(ARMES_SHOP)))
                return {"niv": niv, "argent": arg, "nb": nb + 1}
    except:
        return None
    return None

