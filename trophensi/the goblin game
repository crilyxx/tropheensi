            carte[lig][0] = 1
            carte[lig][nb_cols - 1] = 1

        # --- Blocs d'obstacles intérieurs (astéroïdes / plateformes spatiales) ---
        blocs = [
            # format : (lig_debut, col_debut, hauteur, largeur)
            (4,  8,  3, 4),   # bloc NW
            (4,  25, 3, 5),   # bloc N centre-gauche
            (4,  42, 3, 4),   # bloc N centre-droit
            (4,  52, 3, 4),   # bloc NE
            (10, 5,  4, 3),   # bloc W haut
