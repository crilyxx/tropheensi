def calcul_camera(joueur, carte_actuelle):
    cam_x = joueur["x"] - screen_width // 2
    cam_y = joueur["y"] - screen_height // 2
    if not carte_actuelle or not carte_actuelle[0]:
        return max(0, cam_x), max(0, cam_y)
    largeur_carte = len(carte_actuelle[0]) * TAILLE_TUILE
    hauteur_carte = len(carte_actuelle) * TAILLE_TUILE
    max_cam_x = max(0, largeur_carte - screen_width)
    max_cam_y = max(0, hauteur_carte - screen_height)
    cam_x = max(0, min(cam_x, max_cam_x))
    cam_y = max(0, min(cam_y, max_cam_y))
    return cam_x, cam_y

