        "poing": 50, "gourdin": 100, "dague": 150, "epee": 200,
        "faux": 250, "lance": 300, "hache": 350, "trident": 400,
        "arbalete": 450, "marteau": 500, "foudre": 600, "katana": 700,
         "cimeterre": 350, "fouet": 320,
        "harpon": 500, "sabre_mer": 480, "pic": 600, "masse_glace": 650,
        "laser": 800, "plasma_gun": 900,
    }
    return base.get(arme, 300) * (2 ** niveau_actuel)

def get_degats_arme(arme):
    """Retourne les dégâts réels de l'arme avec les upgrades appliqués."""
    base = armes_stats[arme]["degats"]
    niv = armes_niveaux.get(arme, 0)
    return int(base * (1 + niv * 0.20))  # +20% par niveau d'upgrade

def get_portee_arme(arme):
    base = armes_stats[arme]["portee"]
    niv = armes_niveaux.get(arme, 0)
    return int(base * (1 + niv * 0.10))  # +10% portée par niveau

def get_cooldown_arme(arme):
    base = armes_stats[arme]["cooldown"]
    niv = armes_niveaux.get(arme, 0)
    return max(2, int(base * (1 - niv * 0.08)))  # -8% CD par niveau

