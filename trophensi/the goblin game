    difficulte = 1.0 + (numero_vague_infinie - 1) * 0.08

    # Nombre d'ennemis : commence a 8, +2 par vague, plafond a 40
    ennemis_par_vague = min(40, 8 + numero_vague_infinie * 2)

    # Delai entre spawns : commence a 120 et descend jusqu'a 35
    delai_ennemi = max(35, 120 - numero_vague_infinie * 4)

    # Une seule vague par round en mode infini
    nb_vagues_total = 1
    vague_actuelle  = 1

    ennemis_spawnes_vague = 0
    ennemis_tues_vague    = 0
    timer_ennemi          = 0
    boss_actif            = None
    boss_spawne           = False

    # Boss toutes les 5 vagues
    if numero_vague_infinie % 5 == 0:
        if numero_vague_infinie == 5:
            boss_type_niveau = "troll"
        elif numero_vague_infinie == 10:
            boss_type_niveau = "chamane"
        elif numero_vague_infinie == 15:
            boss_type_niveau = "roi"
        else:
            boss_type_niveau = random.choice(["troll", "chamane", "roi"])
    else:
        boss_type_niveau = None

    # Scaling des ennemis depuis les stats de base
    for i in range(len(types_gobelins["foret"])):
        base = STATS_BASE_GOBELINS["foret"][i]
        types_gobelins["foret"][i]["hp"]      = int(base["hp"]      * difficulte)
        types_gobelins["foret"][i]["degats"]  =     base["degats"]  * difficulte

        # Vitesse : +1 tous les 5 vagues (encore plus progressif), plafond a 7
        nouvelle_vitesse = base["vitesse"] + numero_vague_infinie // 5
        if nouvelle_vitesse > 7:
            nouvelle_vitesse = 7
        types_gobelins["foret"][i]["vitesse"] = nouvelle_vitesse

    # Le magnetisme donne des pieces bonus au debut de chaque vague
    if bonus_magnet > 0:
        argent_infini = argent_infini + bonus_magnet

    # Soin partiel entre les vagues : +5 HP (encourage a continuer)
    joueur["hp"] = min(joueur["hp_max"], joueur["hp"] + 5)

