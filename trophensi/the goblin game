    if mode_infini:
        vitesse_joueur = joueur["vitesse"] + bonus_vitesse
    else:
        vitesse_joueur = joueur["vitesse"] + bonus_comp["bonus_vitesse"]

    if touches[pygame.K_z]: dy -= vitesse_joueur
    if touches[pygame.K_s]: dy += vitesse_joueur
    if touches[pygame.K_q]: dx -= vitesse_joueur
    if touches[pygame.K_d]: dx += vitesse_joueur

